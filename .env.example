# ============================================================
# ⚪ デモ版環境変数
# 本番テンプレ (rapportia-liff) で必要な AMELIA_* は不要。
# ============================================================

# --- LINE ---
NEXT_PUBLIC_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_SHOP_OWNER_USER_ID=

# --- Stripe (テストモード可) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- 自身のフルURL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- 共通 ---
DEPOSIT_AMOUNT_JPY=2000

# --- 店主用 予約管理画面 (/admin) ---
# 合言葉（未設定時は "cake-demo"）。商談前に変更推奨。
ADMIN_PASSCODE=cake-demo

# 予約の保存先 KV (Upstash / Vercel KV)。
# 未設定ならプロセス内メモリで動作（ローカル開発はこれでOK）。
# 「スマホ予約→PC管理画面に反映」を本番デモで見せるには Vercel に設定する。
KV_REST_API_URL=
KV_REST_API_TOKEN=
