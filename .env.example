# ============================================================
# ⚪ デモ版環境変数
# 本番テンプレ (rapportia-liff) で必要な AMELIA_* は不要。
# ============================================================

# --- LINE ---
NEXT_PUBLIC_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_SHOP_OWNER_USER_ID=

# --- Stripe (テストモード可) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- 自身のフルURL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- 共通 ---
DEPOSIT_AMOUNT_JPY=2000

# --- 店主・スタッフ用 予約管理画面 (/admin) ---
# 合言葉は廃止。LINE ログイン + LINE ユーザーID 許可リストで認証（複数管理者対応）。
# 管理画面に入れる管理者の LINE userId をカンマ区切りで列挙（U+32文字）。
# 各管理者は /admin/login を開くと自分の userId が表示されるので、それをここに追記して再デプロイ。
ADMIN_LINE_USER_IDS=
# 管理者セッション Cookie の HMAC 署名鍵（任意の十分長いランダム文字列。未設定時は開発用デフォルト）。
ADMIN_SESSION_SECRET=

# 予約の保存先 Supabase (Postgres)。
# 未設定ならプロセス内メモリで動作（ローカル開発はこれでOK）。
# 「スマホ予約→PC管理画面に反映」を本番デモで見せるには Vercel に設定する。
# SERVICE_ROLE_KEY はサーバー専用・絶対にクライアントへ出さないこと（RLS をバイパスする鍵）。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 複数デモを1プロジェクトに相乗りさせる時のテナント識別子（未設定なら "cake"）。
DEMO_ID=cake

# keep-alive cron の保護用シークレット（任意）。設定すると /api/keep-alive が
# Authorization: Bearer <値> を要求する。Vercel Cron は自動でこのヘッダを付与する。
CRON_SECRET=
