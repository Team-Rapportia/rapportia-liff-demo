# ============================================================
# クライアント側に露出してよい (NEXT_PUBLIC_*)
# ============================================================

# LIFF アプリ ID (LINE Developers Console)
NEXT_PUBLIC_LIFF_ID=

# Stripe 公開キー (pk_test_... or pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# 自身のフルURL（success_url/cancel_url 生成用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# サーバー専用 - 絶対にクライアントへ漏らさない
# ============================================================

# LINE Login Channel ID (LIFF ID Token 検証用、'aud' チェック)
LINE_LOGIN_CHANNEL_ID=

# LINE Messaging API（店舗側 push 用）
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_SHOP_OWNER_USER_ID=

# Stripe シークレット
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Amelia REST API（顧客の WordPress）
AMELIA_API_BASE=https://example.com/wp-json/amelia/v1
AMELIA_API_KEY=

# Stripe Checkout で取得する deposit 金額（円）
DEPOSIT_AMOUNT_JPY=2000
